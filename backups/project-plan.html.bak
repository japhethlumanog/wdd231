<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Project site plan for the Sava City Chamber project."
    />
    <meta name="author" content="Japheth James D. Lumanog" />
    <title>Project Plan — Sava City Chamber</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <link rel="stylesheet" href="styles/normalize.css" />
    <link rel="stylesheet" href="styles/small.css" />
    <link rel="stylesheet" href="styles/large.css" />
    <link rel="stylesheet" href="styles/plan.css" />

    <script src="scripts/navigation.js" defer></script>
    <script src="scripts/dates.js" defer></script>
  </head>
  <body>
    <header>
      <div class="header-inner">
        <div class="logo-group">
          <img src="images/site-logo.svg" alt="Site Logo" class="site-logo" />
          <span class="site-name">Japheth James D. Lumanog</span>
        </div>
        <button class="hamburger" id="hamburger">
          <span></span><span></span><span></span>
        </button>
      </div>
      <nav id="nav-menu">
        <ul>
          <li><a href="index.html">Home</a></li>
          <li><a href="chamber/index.html">Chamber</a></li>
          <li><a href="final/index.html">Final</a></li>
        </ul>
      </nav>
    </header>

    <main id="plan" class="container">
      <h1>Project Site Plan — Sava City Chamber</h1>

      <section id="site-name">
        <h2>Site Name</h2>
        <p><strong>Sava City Chamber of Commerce</strong></p>
        <p>
          Chosen to represent the local chamber and its community services.
          Optional domain: <code>savacitychamber.org</code>
        </p>
      </section>

      <section id="purpose">
        <h2>Site Purpose</h2>
        <p>
          The site connects local businesses, promotes events, highlights member
          spotlights, and provides a directory and membership signup to grow the
          local economy.
        </p>
      </section>

      <section id="scenarios">
        <h2>Scenarios</h2>
        <ul>
          <li>Where can I find local businesses offering services I need?</li>
          <li>
            How do I join the chamber and list my business in the directory?
          </li>
        </ul>
      </section>

      <section id="color-scheme">
        <h2>Color Scheme</h2>
        <p>Primary colors (where used):</p>
        <ul>
          <li>
            <strong>Deep Blue</strong> (#264653) — header/footer background,
            strong accents
          </li>
          <li>
            <strong>Warm Teal</strong> (#2A9D8F) — buttons, links, highlights
          </li>
          <li>
            <strong>Light Off-white</strong> (#F7FEFC) — page background and
            large surfaces
          </li>
        </ul>
      </section>

      <section id="typography">
        <h2>Typography</h2>
        <ul>
          <li>
            <strong>DM Serif Display</strong> — used for hero titles and large
            headings.
          </li>
          <li>
            <strong>DM Sans</strong> — body text and UI elements for
            readability.
          </li>
        </ul>
      </section>

      <section id="wireframe">
        <h2>Wireframe</h2>
        <p>
          Mobile: stacked header & nav, hero image, events list, directory link,
          footer. Desktop: header + nav, large hero with CTA, two-column content
          (main + sidebar with CTA and spotlight), footer.
        </p>
      </section>
    </main>

    <footer>
      <div class="footer-meta">
        <p id="copyright"></p>
        <p>Japheth James D. Lumanog &bull; Philippines</p>
      </div>

      <div class="footer-social">
        <a
          href="https://github.com/yourusername"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path
              d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
            />
          </svg>
          GitHub
        </a>
        <a
          href="https://linkedin.com/in/yourusername"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            />
          </svg>
          LinkedIn
        </a>
        <a
          href="https://twitter.com/yourusername"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg viewBox="0 0 24 24" focusable="false">
            <path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.259 5.63 5.905-5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"
            />
          </svg>
          Twitter/X
        </a>
      </div>

      <div class="footer-modified">
        <p id="lastModified"></p>
      </div>
    </footer>
  </body>
</html>